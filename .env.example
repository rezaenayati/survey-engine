# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=survey_engine

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all
CORS_ORIGINS=*

# ─── API Key (optional) ────────────────────────────────────────────────────────
# When set, every request must include one of:
#   Authorization: Bearer <key>
#   X-API-Key: <key>
# Leave unset (or empty) to allow all requests — suitable for internal networks.
# API_KEY=change-me-in-production

# ─── Webhooks (optional) ───────────────────────────────────────────────────────
# Global HMAC-SHA256 secret used to sign webhook payloads when a per-survey
# secret is not configured. Receivers verify with:
#   X-Survey-Engine-Signature: sha256=<hex>
# Leave unset to send unsigned webhooks.
# WEBHOOK_SECRET=change-me-in-production

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Logging ───────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
