# URL of your running survey-engine instance (server-side Next.js routes)
SURVEY_ENGINE_URL=http://localhost:3000

# Same origin, exposed to the browser — used for file preview URLs if the engine
# does not return `url` on upload. Match `SURVEY_ENGINE_URL` in local dev.
NEXT_PUBLIC_SURVEY_ENGINE_URL=http://localhost:3000

# Survey-engine repo root `.env` — recommended for local file storage + URLs in upload JSON:
# FILE_STORAGE_DRIVER=local
# FILE_LOCAL_DIR=uploads
# FILE_PUBLIC_BASE_URL=http://localhost:3000

# Optional: API key if survey-engine is configured with API_KEY
# SURVEY_ENGINE_API_KEY=your-key-here
