{
  "name": "survey-engine-sdk",
  "version": "1.0.1",
  "description": "TypeScript SDK for the Survey Engine API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "survey",
    "surveyjs",
    "forms",
    "sdk",
    "backend"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rezaenayati/survey-engine.git",
    "directory": "sdk"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
